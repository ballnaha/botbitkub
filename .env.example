# API Key และ API Secret จากบัญชี Bitkub ของคุณ
BITKUB_API_KEY=your_bitkub_api_key_here
BITKUB_API_SECRET=your_bitkub_api_secret_here

# ชื่อเจ้าของบัญชีสำหรับแสดงผลบนหน้าจอแดชบอร์ด
BITKUB_OWNER_NAME=Guest

# ยืนยันตัวตนสำหรับเข้าหน้าเว็บ Dashboard (HTTP Basic Auth)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=password123

# API Key ของผู้ให้บริการ AI ที่ระบบรองรับปัจจุบัน (Gemini) สำหรับช่วยกรองสัญญาณซื้อขาย
GEMINI_API_KEY=your_gemini_api_key_here

# การตั้งค่าพอร์ตและโฮสต์ (ปกติใช้ค่าเริ่มต้นได้เลย)
HOST=127.0.0.1
PORT=8282
